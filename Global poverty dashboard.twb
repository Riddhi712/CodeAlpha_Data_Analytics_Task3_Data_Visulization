      <column caption=' Income Group Classification' datatype='string' name='[Calculation_0888411577028608]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [gdp_per_capita_usd] &gt;= 12000 THEN &quot;High Income&quot;&#13;&#10;ELSEIF [gdp_per_capita_usd] &gt;= 4000 THEN &quot;Upper-Middle&quot;&#13;&#10;ELSEIF [gdp_per_capita_usd] &gt;= 1000 THEN &quot;Lower-Middle&quot;&#13;&#10;ELSE &quot;Low Income&quot;&#13;&#10;END' />
